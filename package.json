{
  "name": "pdf-editor",
  "version": "1.0.2",
  "private": true,
  "homepage": "https://royavidan.github.io/PdfEditor",
  "dependencies": {
    "@pdf-lib/fontkit": "^0.0.4",
    "file-saver": "^2.0.2",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.0.1",
    "pdfjs-dist": "2.16.105",
    "prop-types": "^15.5.7",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "react-files": "^2.4.8",
    "react-keyboard-event-handler": "^1.5.1",
    "react-scripts": "^3.4.1",
    "worker-loader": "^3.0.8",
    "xml-js": "^1.6.11"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "release": "np",
    "jest": "jest",
    "predeploy": "npm run release && npm run build",
    "deploy": "gh-pages -d build && git push --follow-tags"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "jest": {
    "moduleNameMapper": {
      "^worker-loader!(?:.+[\\\/])*([^\\\/]+)$": "<rootDir>/src/test-utils/mocks/$1"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.1",
    "@types/jest": "^24.9.0",
    "@types/react": "^16.8.6",
    "@types/react-dom": "^16.9.25",
    "@types/react-keyboard-event-handler": "^1.5.1",
    "gh-pages": "^2.1.1",
    "np": "^6.2.0",
    "sass": "^1.78.0",
    "typescript": "^3.9.10"
  }
}