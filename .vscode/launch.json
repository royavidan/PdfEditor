{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Auto",
      "type": "auto-debug",
      "request": "launch",
      "map": {
        "*.test.ts": "Debug Test File",
        "*.test.tsx": "Debug Test File",
        "*": "Launch Chrome"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Test File",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "${file}"
      ],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:5173/PdfEditor",
      "webRoot": "${workspaceFolder}"
    },
    
  ]
}